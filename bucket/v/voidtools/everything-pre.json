{
    "version": "1.5.0.1413b",
    "description": "A pre-release, high-performance search engine for Windows, engineered for instantaneous file and directory retrieval by name.",
    "homepage": "https://www.voidtools.com",
    "license": {
        "identifier": "MIT",
        "url": "https://www.voidtools.com/License.txt"
    },
    "notes": [
        "To register file associations, please execute the following command:",
        "- `reg import \"$dir\\register-file-associations.reg\"`",
        "To register application startup, please execute the following command:",
        "- `reg import \"$dir\\register-startup-entry.reg\"`",
        "To register the context menu entry, please execute the following command:",
        "- `reg import \"$dir\\register-context-menu.reg\"`",
        "To register the URL protocol handler, please execute the following command:",
        "- `reg import \"$dir\\register-url-handler.reg\"`"
    ],
    "architecture": {
        "64bit": {
            "url": "https://www.voidtools.com/Everything-1.5.0.1413b.x64.zip",
            "hash": "638ba3b4e187b07bd73cdee24bf7863a962ec865716e6a7e521cbb04f7edd29f"
        },
        "32bit": {
            "url": "https://www.voidtools.com/Everything-1.5.0.1413b.x86.zip",
            "hash": "b4d7a8eb0c3bc0a9d36ff082f1df26c1f8f440924877590cc8a6ad8bc7eda82a"
        }
    },
    "pre_install": [
        "Get-ChildItem -Path $dir -Filter '*.exe' -File | ForEach-Object -Process {",
        "    $new_name = [regex]::Replace($_.BaseName, '^(\\w)([^A-Z0-9]*).*', {",
        "            $args[0].Groups[1].Value.ToUpper() + $args[0].Groups[2].Value + '.exe'",
        "        })",
        "    if ($_.Name -cne $new_name) { $_ | Rename-Item -NewName $new_name -Force }",
        "}",
        "if (-not (Test-Path -Path \"$persist_dir\\*.ini\" -PathType Leaf)) {",
        "    Start-Process -FilePath \"$dir\\Everything.exe\" -ArgumentList @('-install-config', 'null') -NoNewWindow -Wait",
        "}",
        "# Hard links are not applicable here because the application creates a new file instead of modifying the existing one in place.",
        "if ($cmd -eq 'install' -and -not (Test-Path -Path \"$persist_dir\\*\")) { return }",
        "'*.db', '*.csv', '*.ico', '*.ini', '*.txt', 'Session*.json', 'NO_ALPHA_INSTANCE' | ForEach-Object -Process {",
        "    if (Test-Path -Path \"$persist_dir\\$_\" -PathType Leaf) {",
        "        Copy-Item -Path \"$persist_dir\\$_\" -Destination $dir -Force",
        "    }",
        "}"
    ],
    "post_install": [
        "$everything_pre_dir = $dir -replace '\\\\', '\\\\'",
        "Get-ChildItem -Path \"$bucketsdir\\$bucket\\scripts\\$app\" -Filter '*.reg' -File | ForEach-Object -Process {",
        "    $content = Get-Content -Path $_.FullName -Encoding utf8",
        "    if ($global) { $content = $content -replace 'HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE' }",
        "    $content -replace '{{everything_pre_dir}}', $everything_pre_dir | Set-Content -Path \"$dir\\$($_.Name)\" -Encoding unicode",
        "}"
    ],
    "bin": "Everything.exe",
    "shortcuts": [
        [
            "Everything.exe",
            "Everything"
        ]
    ],
    "persist": [
        "Logs",
        "plugins",
        "HTTP server"
    ],
    "pre_uninstall": [
        "# Hard links are not applicable here because the application creates a new file instead of modifying the existing one in place.",
        "if ($cmd -eq 'uninstall' -and $purge) { return }",
        "'*.db', '*.csv', '*.ico', '*.ini', '*.txt', 'Session*.json', 'NO_ALPHA_INSTANCE' | ForEach-Object -Process {",
        "    if (Test-Path -Path \"$dir\\$_\" -PathType Leaf) {",
        "        Copy-Item -Path \"$dir\\$_\" -Destination $persist_dir -Force",
        "    }",
        "}"
    ],
    "uninstaller": {
        "script": [
            "if ($cmd -eq 'uninstall') {",
            "    Get-ChildItem -Path $dir -Filter 'un*.reg' -File | ForEach-Object -Process {",
            "        $registry_file = '\"{0}\"' -f $_.FullName",
            "        Start-Process -FilePath 'reg.exe' -ArgumentList @('import', $registry_file) -WindowStyle Hidden -Wait",
            "    }",
            "}",
            "$base_name = 'Everything'",
            "$path_regex = [regex]::Escape((Split-Path -Path $dir -Parent))",
            "$process = Get-Process -Name $base_name -ErrorAction SilentlyContinue | Where-Object -FilterScript { $_.Path -match $path_regex }",
            "if ($process.Count -gt 0) {",
            "    Write-Host \"`nINFO  Identified $($process.Count) running processes for termination.\" -ForegroundColor DarkGray",
            "    Stop-Process -Id $process.Id -Force -ErrorAction SilentlyContinue",
            "}",
            "if ($PSVersionTable.PSVersion -ge [version]::new(6, 0)) {",
            "    $services = Get-Service -Name \"*$base_name*\" -ErrorAction SilentlyContinue",
            "} else {",
            "    $name_filter = \"Name like '%$base_name%'\"",
            "    $services = Get-CimInstance -ClassName Win32_Service -Filter $name_filter -ErrorAction SilentlyContinue |",
            "            Select-Object -Property *, @{ Name = 'BinaryPathName'; Expression = { $_.PathName } }",
            "}",
            "$service = $services | Where-Object -FilterScript { $_.BinaryPathName -match $path_regex }",
            "if ($null -ne $service) {",
            "    if (-not (is_admin)) { abort \"`n[ERROR]  $app requires admin rights to $cmd.\" }",
            "    Stop-Service -Name $service.Name -Force -ErrorAction SilentlyContinue",
            "    $process.Id | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
            "        Get-Process -Id $_ -ErrorAction SilentlyContinue | Where-Object -FilterScript { $_.Name -like \"*$base_name*\" }",
            "    } | Stop-Process -Force -ErrorAction SilentlyContinue",
            "    Start-Sleep -Milliseconds 1500",
            "    if ($cmd -ne 'uninstall') { return }",
            "    $service.Name | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
            "        if ($PSVersionTable.PSVersion -ge [version]::new(6, 0)) {",
            "            Remove-Service -Name $_ -ErrorAction SilentlyContinue",
            "        } else {",
            "            Start-Process -FilePath 'sc.exe' -ArgumentList @('delete', $_) -NoNewWindow -Wait",
            "        }",
            "    }",
            "}"
        ]
    },
    "post_uninstall": [
        "if ($cmd -ne 'uninstall') { return }",
        "$registry_hive = if ($global) { 'HKLM' } else { 'HKCU' }",
        "$cleanup_tasks = @(",
        "    @{ Path = \"${registry_hive}:\\Software\\Classes\\Folder\\shell\" }",
        "    @{ Path = \"${registry_hive}:\\Software\\Classes\\Directory\\background\\shell\" }",
        "    @{ Path = \"${registry_hive}:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run\" }",
        ")",
        "foreach ($task in $cleanup_tasks) {",
        "    if (-not (Test-Path -Path $task.Path)) { continue }",
        "    Get-ChildItem -Path $task.Path | Where-Object -FilterScript { $_.PSChildName -like 'Search Everything*' } |",
        "            Remove-Item -Recurse -Force -ErrorAction SilentlyContinue",
        "    Get-Item -Path $task.Path | ForEach-Object -MemberName GetValueNames |",
        "        Where-Object -FilterScript { $_ -like 'Everything*' } | ForEach-Object -Process {",
        "            Remove-ItemProperty -Path $task.Path -Name $_ -Force -ErrorAction SilentlyContinue",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.voidtools.com/forum/viewtopic.php?sd=d&t=9787",
        "regex": "Everything-([\\d.]+\\w)\\.x64"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.voidtools.com/Everything-$version.x64.zip"
            },
            "32bit": {
                "url": "https://www.voidtools.com/Everything-$version.x86.zip"
            }
        }
    }
}
