{
    "version": "2.937",
    "description": "A large collection of GNU and Open Source tools which provide functionality similar to a Linux distribution on Windows.",
    "homepage": "https://cygwin.com",
    "license": {
        "identifier": "X11, Public Domain, GPL-3.0-or-later",
        "url": "https://cygwin.com/faq.html#faq.what.free"
    },
    "notes": [
        "Due to the specific output behavior of `cygwin-setup.exe`, executing `cygwin-setup <option>` directly in a terminal may not display any output.",
        "To display the corresponding output, use a pipe to forward the result to the console.",
        "In Command Prompt (cmd), execute `cygwin-setup <option> | more` to display the output.",
        "In PowerShell, execute `cygwin-setup <option> | Out-GridView` to display the output in a graphical view.",
        "The Out-GridView cmdlet requires a graphical user interface and is unsupported on Windows Server Core and similar environments.",
        "In such environments, `Write-Output` or `Out-Host` may be used as alternatives when output display is required."
    ],
    "architecture": {
        "64bit": {
            "url": "https://cygwin.com/setup/setup-2.937.x86_64.exe#/cygwin-setup.exe",
            "hash": "sha512:6acea47c59781c9e7f544a18d53935d59df6e44d5d52ac95ee165671b8e388820455eebf30ccc7d254b00c3d0eb694269a0f8dc84b17944c1f355dac9c5aafcc"
        },
        "32bit": {
            "url": "https://cygwin.com/setup/setup-2.937.x86.exe#/cygwin-setup.exe",
            "hash": "sha512:cde28403134e9a24d21dfac571658df0816eb89f1a05fba6e5c20789b794b2c824a63ac87c5eae77a58e0b461823436c7bf6533515bf1ddb19d50d328d6dd221"
        }
    },
    "installer": {
        "script": [
            "'root', 'packages' | Foreach-Object -Process { ensure \"$persist_dir\\$_\" | Out-Null }",
            "$install_args = @(",
            "    '--site', 'https://mirrors.kernel.org/sourceware/cygwin/'",
            "    '--no-admin', '--no-shortcuts', '--quiet-mode', '--upgrade-also'",
            "    '--local-package-dir', \"$persist_dir\\packages\", '--root', \"$persist_dir\\root\"",
            ")",
            "Start-Process -FilePath \"$dir\\cygwin-setup.exe\" -ArgumentList $install_args -WindowStyle 'Hidden' -Wait",
            "persist_data @{ persist = @('root', 'packages') } $original_dir $persist_dir",
            "persist_permission @{ persist = @('root', 'packages') } $global"
        ]
    },
    "bin": [
        [
            "cygwin-setup.exe",
            "cygwin-setup",
            "--no-admin --no-shortcuts --no-version-check --local-package-dir \"$persist_dir\\packages\" --root \"$persist_dir\\root\""
        ],
        [
            "root\\bin\\bash.exe",
            "cygwin",
            "--login -i"
        ]
    ],
    "shortcuts": [
        [
            "root\\Cygwin.bat",
            "Cygwin\\Cygwin",
            "",
            "root\\Cygwin-Terminal.ico"
        ],
        [
            "cygwin-setup.exe",
            "Cygwin\\Cygwin Setup",
            "--no-admin --no-shortcuts --no-version-check --local-package-dir \"$persist_dir\\packages\" --root \"$persist_dir\\root\""
        ],
        [
            "root\\bin\\mintty.exe",
            "Cygwin\\Cygwin Terminal",
            "-i /Cygwin-Terminal.ico -",
            "root\\Cygwin-Terminal.ico"
        ]
    ],
    "uninstaller": {
        "script": "unlink_persist_data @{ persist = @('root', 'packages') } $dir"
    },
    "checkver": {
        "script": [
            "$release_url = 'https://cygwin.com/setup/'",
            "$version_sort = { if ($_.href.Replace('.x86_64.exe', '') -match `",
            "    '(?<=setup-)[\\d.]+$') { [version]$matches[0] } else { [version]::new(0, 0, 0) } }",
            "$release_page = Invoke-WebRequest -Uri $release_url -UseBasicParsing -ErrorAction Stop",
            "$package_names = $release_page.links | Where-Object { $_.href -like '*.x86_64.exe' } |",
            "        Sort-Object -Property $version_sort -Descending | ForEach-Object -MemberName href",
            "$latest_version = $package_names[0] -replace 'setup-([\\d.]+).+', '$1' -replace '\\.$', ''",
            "Write-Output $latest_version"
        ],
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cygwin.com/setup/setup-$version.x86_64.exe#/cygwin-setup.exe"
            },
            "32bit": {
                "url": "https://cygwin.com/setup/setup-$version.x86.exe#/cygwin-setup.exe"
            }
        },
        "hash": {
            "url": "https://cygwin.com/setup/sha512.sum"
        }
    }
}
