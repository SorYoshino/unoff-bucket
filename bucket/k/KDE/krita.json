{
    "version": "5.2.16",
    "description": "A professional free and open-source digital painting application.",
    "homepage": "https://krita.org/",
    "license": {
        "identifier": "GPL-3.0-only",
        "url": "https://krita.org/en/about/license/"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/krita/5.2.16/krita-x64-5.2.16.zip",
            "hash": "5b135f70ed47aa01c4b4fadf40a66b2ab1cacc58836c0bf5c8bd34eeae1a5442",
            "extract_dir": "krita-x64-5.2.16"
        }
    },
    "bin": [
        "bin\\krita.exe",
        "bin\\kritarunner.exe"
    ],
    "shortcuts": [
        [
            "bin\\krita.exe",
            "Krita"
        ]
    ],
    "checkver": {
        "url": "https://krita.org/en/download/",
        "regex": "Download Krita\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/krita/$version/krita-x64-$version.zip",
                "hash": {
                    "url": "$url.sha256"
                },
                "extract_dir": "krita-x64-$version"
            }
        }
    }
}
