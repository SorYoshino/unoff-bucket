{
    "version": "6075-g169694ebd",
    "description": "A compact Windows port of BusyBox that provides a single native executable implementing a broad set of  Unix-style command-line utilities, suitable for lightweight scripting and command-line use on Windows.",
    "homepage": "https://frippery.org/busybox/index.html",
    "license": {
        "identifier": "GPL-2.0-only",
        "url": "https://github.com/rmyorston/busybox-w32/blob/HEAD/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://frippery.org/files/busybox/busybox-w64u-FRP-6075-g169694ebd.exe#/busybox.exe",
            "hash": "6e263d154d8548d1eb936f65d1d8312c80df31c45974e48d6335e4dcc0f4f34c"
        },
        "32bit": {
            "url": "https://frippery.org/files/busybox/busybox-w32-FRP-6075-g169694ebd.exe#/busybox.exe",
            "hash": "7bfee530965315665044e6e01db58125f2763c8a39c2e72ba1a6beb6923e0e1f"
        },
        "arm64": {
            "url": "https://frippery.org/files/busybox/busybox-w64a-FRP-6075-g169694ebd.exe#/busybox.exe",
            "hash": "e67f873d19d58c535cc9f0c4965ffd622e19b7bab87e3da89cb2185fb54464d7"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$HOME\\.profile\" -PathType Leaf)) {",
        "    Write-Host \"`nINFO  Creating '~/.profile'...\" -ForegroundColor DarkGray",
        "    $cfg = @('if [ -f ~/.bashrc ]; then', '    source ~/.bashrc', 'fi')",
        "    Set-Content -Path \"$HOME\\.profile\" -Value $cfg -Encoding oem",
        "}"
    ],
    "post_install": [
        "$process_info = [System.Diagnostics.ProcessStartInfo]@{",
        "    FileName = \"$original_dir\\busybox.exe\"; Arguments = '--list'",
        "    CreateNoWindow = $true; UseShellExecute = $false; RedirectStandardOutput = $true",
        "}",
        "$process = [System.Diagnostics.Process]::Start($process_info)",
        "$utilities_name = $process.StandardOutput.ReadToEnd() -split \"`r?`n\"",
        "$process.WaitForExit()",
        "Write-Output \"`nCreating shim for 'busybox'....\"",
        "shim \"$original_dir\\busybox.exe\" $global 'busybox' $null",
        "$utilities_name | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
        "    Write-Output \"Creating shim for '$($_.Trim())'...\"",
        "    shim \"$original_dir\\busybox.exe\" $global $_.Trim() $_.Trim()",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$process_info = [System.Diagnostics.ProcessStartInfo]@{",
            "    FileName = \"$dir\\busybox.exe\"; Arguments = '--list'",
            "    CreateNoWindow = $true; UseShellExecute = $false; RedirectStandardOutput = $true",
            "}",
            "$process = [System.Diagnostics.Process]::Start($process_info)",
            "$utilities_name = $process.StandardOutput.ReadToEnd() -split \"`r?`n\"",
            "$process.WaitForExit()",
            "rm_shim 'busybox' $(shimdir $global) $app",
            "$utilities_name | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
            "    rm_shim $_.Trim() $(shimdir $global) $app",
            "}"
        ]
    },
    "checkver": {
        "url": "https://frippery.org/files/busybox/?C=M;O=D",
        "regex": "busybox-w64u-FRP-([\\w-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://frippery.org/files/busybox/busybox-w64u-FRP-$version.exe#/busybox.exe"
            },
            "32bit": {
                "url": "https://frippery.org/files/busybox/busybox-w32-FRP-$version.exe#/busybox.exe"
            },
            "arm64": {
                "url": "https://frippery.org/files/busybox/busybox-w64a-FRP-$version.exe#/busybox.exe"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUM"
        }
    }
}
