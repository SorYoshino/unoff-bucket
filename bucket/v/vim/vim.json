        ]
    ],
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { <# reg import \"$dir\\unregister-context-menu.reg.reg\" #> }"
    },
    "checkver": {
        "github": "https://api.github.com/repos/vim/vim-win32-installer/releases?per_page=45",
        "jsonpath": "$[?(@.prerelease == false)].assets[?(@.name =~ /signed\\.zip/i)].browser_download_url",
        "regex": "(?i)download/(?<tag>[^/]+)/gvim_([\\d.]+)_(?:x|arm)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/vim/vim-win32-installer/releases/download/$matchTag/gvim_$version_x64_signed.zip"
            },
            "32bit": {
                "url": "https://github.com/vim/vim-win32-installer/releases/download/$matchTag/gvim_$version_x86_signed.zip"
            },
            "arm64": {
                "url": "https://github.com/vim/vim-win32-installer/releases/download/$matchTag/gvim_$version_arm64_signed.zip"
            }
        },
        "extract_dir": "vim/vim$majorVersion$minorVersion"
    }
