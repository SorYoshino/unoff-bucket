{
    "version": "26.04-2076",
    "description": "An application that visualizes disk usage with an intuitive concentric ring layout, making it easy to identify and free up space.",
    "homepage": "https://apps.kde.org/filelight/",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://cdn.kde.org/ci-builds/utilities/filelight/release-26.04/windows/filelight-release_26.04-2076-windows-cl-msvc2022-x86_64.7z",
            "hash": "28976b68f823f2c2b62f0f61af437fb5b93b39d8cc5cc5ba78ad2fa47a2ca230"
        }
    },
    "bin": "bin\\filelight.exe",
    "shortcuts": [
        [
            "bin\\filelight.exe",
            "Filelight"
        ]
    ],
    "checkver": {
        "script": [
            "$app_type = 'utilities'",
            "$releases_url = 'https://cdn.kde.org/ci-builds/{1}/{0}/' -f $app, $app_type",
            "$version_sort = { if ($_.href -match '([\\d.]+)/$') { [version]$Matches[1] } }",
            "$releases_page = Invoke-WebRequest -Uri $releases_url -UseBasicParsing -ErrorAction Stop",
            "$path_segments = $releases_page.links | Where-Object -FilterScript { $_.href -like 'release-*/' } |",
            "        Sort-Object -Property $version_sort -Descending | ForEach-Object -MemberName href",
            "foreach ($path_segment in $path_segments.TrimEnd('/')) {",
            "    $release_url = 'https://cdn.kde.org/ci-builds/{1}/{0}/{2}/windows/' -f $app, $app_type, $path_segment",
            "    $download_page = Invoke-WebRequest -Uri $release_url -UseBasicParsing -ErrorAction Stop",
            "    $archive_name = $download_page.Links | Where-Object -FilterScript { $_.href -match '\\.7z$' } |",
            "            Select-Object -ExpandProperty href -First 1",
            "    if (-not [string]::IsNullOrWhiteSpace($archive_name)) { Write-Output $archive_name; break }",
            "}"
        ],
        "regex": "filelight-release_([\\d.-]+)-windows-cl-(?<lib>\\w+)-x86_64\\.7z"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.kde.org/ci-builds/utilities/filelight/release-$matchHead/windows/filelight-release_$version-windows-cl-$matchLib-x86_64.7z",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
