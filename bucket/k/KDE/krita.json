{
    "version": "5.3.2.1",
    "description": "A professional free and open-source digital painting application.",
    "homepage": "https://krita.org/",
    "license": {
        "identifier": "GPL-3.0-only",
        "url": "https://krita.org/en/about/license/"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/krita/5.3.2.1/krita-x64-5.3.2.1.zip",
            "hash": "5191527b87b6d7a326f8a5c1d5f237f1ddcec6d24c75ad0fb863723f48222df8",
            "extract_dir": "krita-x64-5.3.2.1"
        }
    },
    "bin": [
        "bin\\krita.exe",
        "bin\\kritarunner.exe"
    ],
    "shortcuts": [
        [
            "bin\\krita.exe",
            "Krita"
        ]
    ],
    "checkver": {
        "url": "https://krita.org/en/download/",
        "regex": "Download Krita\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/krita/$version/krita-x64-$version.zip",
                "hash": {
                    "url": "$url.sha256"
                },
                "extract_dir": "krita-x64-$version"
            }
        }
    }
}
