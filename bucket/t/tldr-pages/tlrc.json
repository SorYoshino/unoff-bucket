{
    "version": "1.13.1",
    "description": "A tldr client written in rust.",
    "homepage": "https://github.com/tldr-pages/tlrc",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/tldr-pages/tlrc/blob/HEAD/LICENSE"
    },
    "notes": "Pages are not bundled with the application and will be automatically downloaded on first use.",
    "suggest": {
        "Microsoft Visual C++ 2015-2022 Redistributable": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tldr-pages/tlrc/releases/download/v1.13.1/tlrc-v1.13.1-x86_64-pc-windows-msvc.zip",
            "hash": "8b85477c935365008214be7a5fd319c56855175ff0c4e8cc2d01fa94accdd210"
        }
    },
    "pre_install": [
        "ensure $persist_dir | Out-Null",
        "$original_cfg_path = $env:TLRC_CONFIG, \"$env:APPDATA\\tlrc\\config.toml\" | Select-Object -First 1",
        "if (-not (Test-Path -Path \"$persist_dir\\*.toml\") -and `",
        "        $original_cfg_path -ne \"$persist_dir\\config.toml\" -and (Test-Path -Path $original_cfg_path -PathType Leaf)) {",
        "    Copy-Item -Path $original_cfg_path -Destination \"$persist_dir\\config.toml\" -Force",
        "    $remove_list = @($env:APPDATA, $env:LOCALAPPDATA) | ForEach-Object -Process { \"$_\\$app\" }",
        "    $remove_list + @($original_cfg_path) | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue",
        "}",
        "$cfg_path = \"$persist_dir\\config.toml\"",
        "if (-not (Test-Path -Path $cfg_path -PathType Leaf)) {",
        "    $process_output_params = @{ NoNewWindow = $true; RedirectStandardOutput = $cfg_path }",
        "    Start-Process -FilePath \"$dir\\tldr.exe\" -ArgumentList @('--gen-config') @process_output_params -Wait",
        "}",
        "$cfg = Get-Content -Path $cfg_path -Encoding utf8",
        "$cfg -replace '(?<=dir = '').+(?='')', \"$persist_dir\\.cache\" -join \"`n\" | Set-Content -Path $cfg_path -Encoding utf8"
    ],
    "env_set": {
        "TLRC_CONFIG": "$persist_dir\\config.toml"
    },
    "bin": "tldr.exe",
    "persist": "config.toml",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tldr-pages/tlrc/releases/download/v$version/tlrc-v$version-x86_64-pc-windows-msvc.zip"
            }
        }
    }
}
