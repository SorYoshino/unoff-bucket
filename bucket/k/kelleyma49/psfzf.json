{
    "version": "2.7.10",
    "description": "A PowerShell wrapper around the fuzzy finder fzf.",
    "homepage": "https://github.com/kelleyma49/PSFzf",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/kelleyma49/PSFzf/blob/HEAD/LICENSE"
    },
    "notes": [
        "Use this module by executing: `Import-Module -Name PSFzf`.",
        "Add the above command to your $PROFILE to enable automatic loading in future sessions."
    ],
    "suggest": {
        "fzf": "fzf"
    },
    "url": "https://cdn.powershellgallery.com/packages/psfzf.2.7.10.nupkg",
    "hash": "a79d172b272029949ad60847187d4a0c1debf1610cc31b7daae53d68f6a93ec5",
    "pre_install": [
        "$remove_list = @('_rels', 'package', '*.nuspec', '*Content*.xml') | ForEach-Object -Process { \"$dir\\$_\" }",
        "$remove_list | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue"
    ],
    "psmodule": {
        "name": "PSFzf"
    },
    "checkver": {
        "url": "https://www.powershellgallery.com/packages/PSFzf",
        "regex": "<h2>([\\d.]+)</h2>"
    },
    "autoupdate": {
        "url": "https://cdn.powershellgallery.com/packages/psfzf.$version.nupkg"
    }
}
