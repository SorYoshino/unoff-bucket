{
    "version": "2.8.20",
    "description": "All-in-one collaboration platform for API documentation, API debugging, API Mock and API test automation.",
    "homepage": "https://apifox.com",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://file-assets.apifox.com/download/2.8.20/Apifox-2.8.20.exe",
            "hash": "sha512:29daea6f7f98d86a166daccdf62792dcd1f3b3511268961916342ccb70954248b6868ccef898b27966a265543a3479597e28715894c826617cf2eddb692b0338"
        }
    },
    "installer": {
        "script": [
            "Expand-7zipArchive -Path \"$dir\\$fname\" -DestinationPath \"$dir\\tmp\" -ExtractDir '$PLUGINSDIR' -Removal",
            "Get-ChildItem -Path \"$dir\\tmp\" -Filter '*.7z' -File | Expand-7zipArchive -DestinationPath $dir -Removal",
            "Remove-Item -Path \"$dir\\tmp\" -Recurse -Force -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "Apifox.exe",
            "Apifox",
            "--user-data-dir=\"$dir\\UserData\""
        ]
    ],
    "persist": "UserData",
    "uninstaller": {
        "script": [
            "Stop-Process -Name 'ApifoxAppAgent' -Force -ErrorAction SilentlyContinue",
            "Start-Sleep -Milliseconds 1500"
        ]
    },
    "checkver": {
        "url": "https://docs.apifox.com/changelog.md",
        "regex": "## ([\\d.]+)(?=\\s)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://file-assets.apifox.com/download/$version/Apifox-$version.exe",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512: $base64"
                }
            }
        }
    }
}
