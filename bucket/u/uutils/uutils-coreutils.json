{
    "version": "0.8.0",
    "description": "A cross-platform Rust reimplementation of GNU coreutils (binaries compiled with MSVC), with some options or behaviors potentially differing from GNU coreutils.",
    "homepage": "https://uutils.github.io/coreutils/",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/uutils/coreutils/blob/HEAD/LICENSE"
    },
    "suggest": {
        "Microsoft Visual C++ 2015-2022 Redistributable": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/uutils/coreutils/releases/download/0.8.0/coreutils-0.8.0-x86_64-pc-windows-msvc.zip",
            "hash": "db464cf2a6ecbfd42c85f46ed2d749be574df4df47feca1f08988fd760f324f3"
        },
        "32bit": {
            "url": "https://github.com/uutils/coreutils/releases/download/0.8.0/coreutils-0.8.0-i686-pc-windows-msvc.zip",
            "hash": "2ffe88b9d81fab6a1625a5f02737c8ab164741447403b92cb84377ac37e1bb39"
        },
        "arm64": {
            "url": "https://github.com/uutils/coreutils/releases/download/0.8.0/coreutils-0.8.0-aarch64-pc-windows-msvc.zip",
            "hash": "1dfa62f18b64c70b664936b06fb1be20f0f6afa9ff041dd95dda629e987435a9"
        }
    },
    "pre_install": [
        "$current_depth = 0",
        "while ($current_depth -lt 5) {",
        "    $items = Get-ChildItem -Path $dir | Select-Object -First 3",
        "    if ($items.Count -eq 1 -and $items.PSIsContainer) {",
        "        $inner_dir = $items | ForEach-Object -MemberName FullName",
        "        Move-Item -Path \"$inner_dir\\*\" -Destination $dir -Force",
        "        Remove-Item -Path $inner_dir -Recurse -Force -ErrorAction SilentlyContinue",
        "        $current_depth++",
        "    } else { break }",
        "}"
    ],
    "post_install": [
        "$program_files = Get-ChildItem -Path $original_dir -Filter '*.exe' -File",
        "if ($program_files.Count -eq 0) { abort \"`nNo executable files found in '$original_dir'. Aborting installation.\" }",
        "if ($program_files.Count -eq 1) {",
        "    $process_info = [System.Diagnostics.ProcessStartInfo]@{",
        "        FileName = $program_files.FullName; Arguments = '--list'",
        "        CreateNoWindow = $true; UseShellExecute = $false; RedirectStandardOutput = $true",
        "    }",
        "    $process = [System.Diagnostics.Process]::Start($process_info)",
        "    $utilities_name = $process.StandardOutput.ReadToEnd() -split \"`r?`n\"",
        "    $process.WaitForExit()",
        "    Write-Output \"`nCreating shim for 'coreutils'...\"",
        "    shim \"$original_dir\\coreutils.exe\" $global 'coreutils' $null",
        "    $utilities_name | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
        "        Write-Output \"Creating shim for '$($_.Trim())'...\"",
        "        shim \"$original_dir\\coreutils.exe\" $global $_.Trim() $_.Trim()",
        "    }",
        "} else {",
        "    $program_files | Foreach-Object -Process {",
        "        Write-Output \"Creating shim for '$($_.BaseName)'...\"",
        "        shim $_.FullName $global $_.BaseName $null",
        "    }",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$program_files = Get-ChildItem -Path $dir -Filter '*.exe' -File",
            "if ($program_files.Count -eq 0) { abort \"`nNo executable files found in '$dir'. Aborting installation.\" }",
            "if ($program_files.Count -eq 1) {",
            "    $process_info = [System.Diagnostics.ProcessStartInfo]@{",
            "        FileName = $program_files.FullName; Arguments = '--list'",
            "        CreateNoWindow = $true; UseShellExecute = $false; RedirectStandardOutput = $true",
            "    }",
            "    $process = [System.Diagnostics.Process]::Start($process_info)",
            "    $utilities_name = $process.StandardOutput.ReadToEnd() -split \"`r?`n\"",
            "    $process.WaitForExit()",
            "    rm_shim 'coreutils' $(shimdir $global) $app",
            "    $utilities_name | Where-Object -FilterScript { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object -Process {",
            "        rm_shim $_.Trim() $(shimdir $global) $app",
            "    }",
            "} else {",
            "    $program_files | ForEach-Object -Process {",
            "        rm_shim $_.BaseName $(shimdir $global) $app",
            "    }",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/uutils/coreutils"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/uutils/coreutils/releases/download/$version/coreutils-$version-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/uutils/coreutils/releases/download/$version/coreutils-$version-i686-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/uutils/coreutils/releases/download/$version/coreutils-$version-aarch64-pc-windows-msvc.zip"
            }
        }
    }
}
